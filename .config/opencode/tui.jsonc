{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "system",
  "keybinds": {
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d",
    "theme_list": "none",
    "username_toggle": "none",
    "model_list": "alt+p",
    "variant_cycle": "alt+r",
    "model_cycle_recent": "none",
    "model_cycle_recent_reverse": "none",
    "agent_list": "alt+a",
    "display_thinking": "alt+t"
  },
  "scroll_acceleration": {
    "enabled": true
  }
}

